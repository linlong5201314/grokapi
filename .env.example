# Grok API 中转站 - 环境变量配置
# 复制此文件为 .env 并填写你的配置
# 在 Vercel 部署时，在 Vercel Dashboard -> Settings -> Environment Variables 中设置

# ==================== 认证配置（二选一）====================

# 方式一：使用 Grok SSO Token（从 grokzhuce 注册工具获得）
# 这是 x.ai 账号的会话令牌（JWT 格式）
GROK_SSO_TOKEN=

# 方式二：使用 xAI 官方 API Key（从 console.x.ai 获取）
# 如果同时设置，优先使用 API Key
GROK_API_KEY=

# ==================== 可选配置 ====================

# xAI 官方 API 基础地址（API Key 模式时使用）
# 默认: https://api.x.ai
GROK_API_BASE=https://api.x.ai

# Grok Web 基础地址（SSO Token 模式时使用）
# 默认: https://grok.x.ai
GROK_WEB_BASE=https://grok.x.ai

# 默认模型
# 默认: grok-3
DEFAULT_MODEL=grok-3

# ==================== 安全配置 ====================

# 保护此中转站的访问令牌（可选）
# 设置后，客户端需要在 Authorization 头中提供此令牌才能使用
# 不设置则允许所有人访问
AUTH_TOKEN=
